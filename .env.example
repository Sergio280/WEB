# ── Culqi ─────────────────────────────────────────────────────────────────────
# Llave secreta del servidor (sk_live_... en producción, sk_test_... en pruebas).
# Panel Culqi → Desarrollo → Llaves. La usan culqi-charge, culqi-subscription y
# culqi-webhook para cobrar y para verificar la autenticidad de los webhooks.
CULQI_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx

# IDs de los planes de suscripción recurrente creados en Culqi (uno por plan).
# Panel Culqi → Suscripciones → Planes. Los consume culqi-subscription.
CULQI_PLAN_INDIVIDUAL=pln_live_xxxxxxxxxxxxxxxx
CULQI_PLAN_PROFESIONAL=pln_live_xxxxxxxxxxxxxxxx

# NOTA: la llave PÚBLICA (pk_live_...) NO va aquí; está embebida en el frontend
# (app-v2/src/data/culqi.js e index.html) porque es pública por diseño.

# ── Firebase ──────────────────────────────────────────────────────────────────
# Cuenta de servicio (Admin SDK) usada por culqi-webhook para activar licencias.
# Firebase Console → Configuración del proyecto → Cuentas de servicio → Generar
# clave privada. Copia los valores del JSON generado:
FIREBASE_PROJECT_ID=bims-8d507
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# API Key PÚBLICA de Firebase (para enviar el email de activación vía REST).
# Firebase Console → Configuración del proyecto → General → apiKey
FIREBASE_API_KEY=AIzaSy_TU_API_KEY_AQUI

# ── Sitio ─────────────────────────────────────────────────────────────────────
# URL pública del sitio (sin barra final). Se usa para la allowlist de Origin
# en las funciones de cobro.
SITE_URL=https://bimsapp.netlify.app
